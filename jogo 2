<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Guerreiro - DragonSlayer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Inter:wght@400;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #070707; color: #e5e7eb; overflow: hidden; }
        .cinzel { font-family: 'Cinzel', serif; }
        .glass-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; }
        .dragon-tap { transition: transform 0.1s; filter: drop-shadow(0 0 20px rgba(245, 158, 11, 0.2)); }
        .dragon-tap:active { transform: scale(0.92); }
        .nav-active { color: #f59e0b; border-bottom: 2px solid #f59e0b; }
        @keyframes float-up { 0% { transform: translateY(0); opacity: 1; } 100% { transform: translateY(-100px); opacity: 0; } }
        .float-text { position: absolute; pointer-events: none; animation: float-up 0.8s ease-out forwards; font-weight: 900; z-index: 50; }
    </style>
</head>
<body class="h-screen w-screen flex flex-col md:flex-row">

    <div id="conn-status" class="fixed top-0 left-0 w-full z-[100] p-1 text-[10px] font-bold text-center uppercase bg-red-600">
        Buscando sinal da Arena...
    </div>

    <aside class="w-full md:w-80 bg-[#0a0a0a] border-r border-white/5 p-6 flex flex-col items-center shrink-0">
        <div class="w-24 h-24 rounded-full border-2 border-amber-500/20 p-1 mb-4">
            <img src="https://images.unsplash.com/photo-1549194388-f61be84a6e9e?q=80&w=400" class="w-full h-full rounded-full object-cover">
        </div>
        <h1 class="cinzel text-lg mb-6">Teu Guerreiro</h1>

        <div class="grid grid-cols-2 gap-2 w-full mb-6">
            <div class="glass-card p-3 text-center">
                <span class="text-[8px] text-gray-500 uppercase font-bold">Ouro Arena</span>
                <span id="stat-gold" class="block text-amber-500 font-black text-xl">0</span>
            </div>
            <div class="glass-card p-3 text-center">
                <span class="text-[8px] text-gray-500 uppercase font-bold">Teu Golpe</span>
                <span id="stat-atk" class="block text-red-500 font-black text-xl">10</span>
            </div>
        </div>

        <div class="w-full glass-card p-4 flex-1 overflow-hidden flex flex-col">
            <p class="text-[8px] text-gray-500 uppercase font-bold mb-2 tracking-widest text-center">Logs Locais</p>
            <div id="local-logs" class="text-[9px] text-gray-500 space-y-1 overflow-y-auto font-mono"></div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative">
        <nav class="flex justify-around p-4 bg-black/50 border-b border-white/5">
            <button onclick="showTab('training')" id="btn-training" class="nav-active px-6 py-2 text-[10px] font-bold uppercase">Treinar</button>
            <button onclick="showTab('market')" id="btn-market" class="px-6 py-2 text-gray-500 text-[10px] font-bold uppercase">Mercado</button>
        </nav>

        <div class="flex-1 flex flex-col items-center justify-center p-6">
            <section id="training-tab" class="tab-content flex flex-col items-center">
                <div class="relative" onclick="doTap(event)">
                    <div class="absolute inset-0 bg-amber-500/5 blur-[80px] rounded-full"></div>
                    <img src="https://cdn-icons-png.flaticon.com/512/1004/1004664.png" class="w-56 h-56 object-contain dragon-tap cursor-pointer relative z-10">
                </div>
                <p class="mt-8 cinzel text-amber-500 text-lg">Forja do Destino</p>
            </section>

            <section id="market-tab" class="tab-content hidden w-full max-w-sm space-y-3">
                <div class="glass-card p-4 flex justify-between items-center">
                    <div>
                        <p class="text-xs font-bold uppercase">Lâmina de Éter</p>
                        <p class="text-[9px] text-gray-500">+5 Ataque</p>
                    </div>
                    <button onclick="buy(5, 100)" class="bg-amber-500 text-black px-4 py-2 rounded font-black text-[10px]">100 G</button>
                </div>
                <div class="glass-card p-4 flex justify-between items-center border-amber-500/30">
                    <div>
                        <p class="text-xs font-bold uppercase">Fúria Dracónica</p>
                        <p class="text-[9px] text-gray-500">+25 Ataque</p>
                    </div>
                    <button onclick="buy(25, 500)" class="bg-amber-500 text-black px-4 py-2 rounded font-black text-[10px]">500 G</button>
                </div>
            </section>
        </div>
    </main>

    <script>
        const TARGET_HOST = "ARENA_DIVINA_OFICIAL_123";
        let myAtk = 10;
        let conn = null;
        let currentGold = 0;
        const peer = new Peer();

        peer.on('open', () => tryConnect());

        function tryConnect() {
            conn = peer.connect(TARGET_HOST);
            
            conn.on('open', () => {
                const s = document.getElementById('conn-status');
                s.innerText = "Conectado à Arena";
                s.className = "fixed top-0 left-0 w-full z-[100] p-1 text-[10px] font-bold text-center uppercase bg-green-600";
                addLog("Alma vinculada ao Host.");
            });

            conn.on('data', data => {
                if (data.gold !== undefined) {
                    currentGold = data.gold;
                    document.getElementById('stat-gold').innerText = Math.floor(currentGold);
                }
            });

            conn.on('close', () => {
                setTimeout(tryConnect, 3000);
            });
        }

        function doTap(e) {
            if (conn && conn.open) {
                conn.send({ type: 'tap', amount: myAtk });
                createFloatText(e.clientX, e.clientY, `+${myAtk}`);
            }
        }

        function buy(power, price) {
            if (currentGold >= price) {
                myAtk += power;
                document.getElementById('stat-atk').innerText = myAtk;
                addLog(`Upgrade: +${power} ATK`);
            }
        }

        function createFloatText(x, y, txt) {
            const el = document.createElement('div');
            el.className = 'float-text text-amber-500 cinzel';
            el.style.left = x + 'px'; el.style.top = y + 'px';
            el.innerText = txt;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 800);
        }

        function showTab(id) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
            document.getElementById(id + '-tab').classList.remove('hidden');
            document.getElementById('btn-training').classList.remove('nav-active');
            document.getElementById('btn-market').classList.remove('nav-active');
            document.getElementById('btn-' + id).classList.add('nav-active');
        }

        function addLog(m) {
            const l = document.getElementById('local-logs');
            l.innerHTML = `<div>> ${m}</div>` + l.innerHTML;
        }
    </script>
</body>
</html>
