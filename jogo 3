<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Guerreiro - Chat & Battle</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Inter:wght@400;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #070707; color: #e5e7eb; overflow: hidden; }
        .cinzel { font-family: 'Cinzel', serif; }
        .glass-card { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; }
        .dragon-tap:active { transform: scale(0.92); }
        .nav-active { color: #f59e0b; border-bottom: 2px solid #f59e0b; }
        .chat-msg { font-size: 10px; margin-bottom: 4px; padding: 4px; border-radius: 4px; background: rgba(255,255,255,0.02); }
    </style>
</head>
<body class="h-screen w-screen flex flex-col md:flex-row">

    <aside class="w-full md:w-80 bg-[#0a0a0a] border-r border-white/5 p-4 flex flex-col shrink-0">
        <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-full border border-amber-500/30 p-1">
                <img src="https://images.unsplash.com/photo-1549194388-f61be84a6e9e?q=80&w=400" class="w-full h-full rounded-full object-cover">
            </div>
            <div>
                <p id="player-id-tag" class="text-[10px] font-mono text-amber-500">Conectando...</p>
                <p class="text-[8px] uppercase text-gray-500">Guerreiro Ativo</p>
            </div>
        </div>

        <div class="grid grid-cols-2 gap-2 mb-4">
            <div class="glass-card p-2 text-center">
                <span class="text-[8px] text-gray-500 uppercase">Ouro</span>
                <span id="stat-gold" class="block text-amber-500 font-black">0</span>
            </div>
            <div class="glass-card p-2 text-center">
                <span class="text-[8px] text-gray-500 uppercase">ATK</span>
                <span id="stat-atk" class="block text-red-500 font-black">10</span>
            </div>
        </div>

        <div class="flex-1 glass-card p-3 flex flex-col overflow-hidden">
            <p class="text-[8px] uppercase text-gray-500 mb-2 font-bold tracking-widest">Chat da Arena</p>
            <div id="chat-messages" class="flex-1 overflow-y-auto mb-2 no-scrollbar"></div>
            <div class="flex gap-1">
                <input type="text" id="chat-input" placeholder="Fala, guerreiro..." class="flex-1 bg-black border border-white/10 rounded px-2 py-1 text-[10px] outline-none focus:border-amber-500">
                <button onclick="sendMsg()" class="bg-amber-500 text-black px-2 rounded text-[10px] font-bold">></button>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative">
        <nav class="flex justify-around p-4 bg-black/50 border-b border-white/5">
            <button onclick="showTab('training')" id="btn-training" class="nav-active px-6 py-2 text-[10px] font-bold uppercase">Treinar</button>
            <button onclick="showTab('market')" id="btn-market" class="px-6 py-2 text-gray-500 text-[10px] font-bold uppercase">Mercado</button>
        </nav>

        <div class="flex-1 flex flex-col items-center justify-center p-6">
            <section id="training-tab" class="tab-content flex flex-col items-center">
                <img src="https://cdn-icons-png.flaticon.com/512/1004/1004664.png" onclick="doTap(event)" class="w-56 h-56 dragon-tap cursor-pointer">
                <p class="mt-8 cinzel text-amber-500">Toque para Forjar</p>
            </section>

            <section id="market-tab" class="tab-content hidden w-full max-w-sm space-y-2">
                <button onclick="buy(5, 100)" class="w-full glass-card p-4 flex justify-between items-center hover:bg-white/5">
                    <span class="text-xs font-bold uppercase">Espada Curta (+5 ATK)</span>
                    <span class="text-amber-500 font-bold">100 G</span>
                </button>
            </section>
        </div>
    </main>

    <script>
        const TARGET_HOST = "ARENA_DIVINA_OFICIAL_123";
        let myAtk = 10;
        let conn = null;
        let currentGold = 0;
        const peer = new Peer();

        peer.on('open', id => { 
            document.getElementById('player-id-tag').innerText = id.substring(0,8);
            tryConnect(); 
        });

        function tryConnect() {
            conn = peer.connect(TARGET_HOST);
            conn.on('open', () => { addChat("Sistema", "Conectado à Arena!"); });
            conn.on('data', data => {
                if (data.gold !== undefined) {
                    currentGold = data.gold;
                    document.getElementById('stat-gold').innerText = Math.floor(currentGold);
                }
                if (data.type === 'chat') {
                    addChat(data.sender, data.text);
                }
            });
            conn.on('close', () => { setTimeout(tryConnect, 3000); });
        }

        function doTap(e) { if (conn && conn.open) conn.send({ type: 'tap', amount: myAtk }); }

        function sendMsg() {
            const input = document.getElementById('chat-input');
            const text = input.value.trim();
            if (text && conn && conn.open) {
                conn.send({ type: 'chat', text: text });
                addChat("Tu", text);
                input.value = "";
            }
        }

        function addChat(s, t) {
            const cm = document.getElementById('chat-messages');
            cm.innerHTML += `<div class="chat-msg"><span class="${s==='Tu'?'text-blue-400':'text-amber-500'} font-bold">${s}:</span> ${t}</div>`;
            cm.scrollTop = cm.scrollHeight;
        }

        function buy(p, c) {
            if (currentGold >= c) {
                myAtk += p;
                document.getElementById('stat-atk').innerText = myAtk;
            }
        }

        function showTab(id) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
            document.getElementById(id + '-tab').classList.remove('hidden');
            document.getElementById('btn-training').className = id === 'training' ? 'nav-active px-6 py-2 text-[10px] font-bold uppercase' : 'px-6 py-2 text-gray-500 text-[10px] font-bold uppercase';
            document.getElementById('btn-market').className = id === 'market' ? 'nav-active px-6 py-2 text-[10px] font-bold uppercase' : 'px-6 py-2 text-gray-500 text-[10px] font-bold uppercase';
        }

        document.getElementById('chat-input').addEventListener('keypress', e => { if(e.key === 'Enter') sendMsg(); });
    </script>
</body>
</html>
