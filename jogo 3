<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <title>Soberano - Arena Host + Chat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Inter:wght@400;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #050505; color: white; overflow: hidden; }
        .cinzel { font-family: 'Cinzel', serif; }
        .log-line { border-left: 2px solid #f59e0b; padding-left: 8px; margin-bottom: 4px; font-size: 10px; color: #9ca3af; }
        .chat-line { margin-bottom: 4px; font-size: 11px; padding: 4px; background: rgba(255,255,255,0.03); border-radius: 4px; }
    </style>
</head>
<body class="h-screen flex p-4 gap-4">

    <aside class="w-96 bg-[#0a0a0a] border border-amber-500/20 rounded-2xl p-6 flex flex-col">
        <h2 class="cinzel text-amber-500 text-xl">Soberano</h2>
        <p id="host-id" class="text-[10px] font-mono text-gray-500 mb-6">Iniciando...</p>

        <div class="grid grid-cols-2 gap-2 mb-6">
            <div class="bg-white/5 p-3 rounded-xl border border-white/5 text-center">
                <p class="text-[8px] text-gray-500 uppercase">Ouro</p>
                <p id="gold-display" class="text-xl font-black text-amber-500">0</p>
            </div>
            <div class="bg-white/5 p-3 rounded-xl border border-white/5 text-center">
                <p class="text-[8px] text-gray-500 uppercase">Players</p>
                <p id="peer-count" class="text-xl font-black text-blue-400">0</p>
            </div>
        </div>

        <p class="text-[10px] text-gray-500 uppercase font-bold mb-2">Chat Global</p>
        <div id="chat-box" class="flex-1 bg-black/50 rounded-xl p-3 overflow-y-auto mb-4 border border-white/5"></div>

        <p class="text-[10px] text-gray-500 uppercase font-bold mb-2">Logs</p>
        <div id="logs" class="h-32 bg-black/50 rounded-xl p-3 overflow-y-auto font-mono border border-white/5"></div>
    </aside>

    <main class="flex-1 bg-[#0a0a0a] border border-white/5 rounded-2xl flex flex-col items-center justify-center relative">
        <h3 class="cinzel text-gray-800 text-4xl uppercase">Arena Ativa</h3>
    </main>

    <script>
        const ARENA_ID = "ARENA_DIVINA_OFICIAL_123"; 
        let totalGold = 0;
        let connections = [];
        const peer = new Peer(ARENA_ID);

        peer.on('open', id => { document.getElementById('host-id').innerText = id; addLog("Arena Pronta."); });

        peer.on('connection', conn => {
            conn.on('open', () => {
                connections.push(conn);
                updateUI();
                addLog(`Entrou: ${conn.peer.substring(0,6)}`);
                conn.send({ type: 'sync', gold: totalGold });
            });

            conn.on('data', data => {
                if (data.type === 'tap') {
                    totalGold += data.amount;
                    updateUI();
                    broadcast({ type: 'update', gold: totalGold });
                }
                if (data.type === 'chat') {
                    const msg = { type: 'chat', sender: conn.peer.substring(0,5), text: data.text };
                    addChat(msg.sender, msg.text);
                    broadcast(msg); // Repassa para todos os outros clientes
                }
            });

            conn.on('close', () => {
                connections = connections.filter(c => c !== conn);
                updateUI();
            });
        });

        function broadcast(data) { connections.forEach(c => c.open && c.send(data)); }
        function updateUI() { 
            document.getElementById('gold-display').innerText = Math.floor(totalGold);
            document.getElementById('peer-count').innerText = connections.length;
        }
        function addLog(m) { const l = document.getElementById('logs'); l.innerHTML = `<div class="log-line">> ${m}</div>` + l.innerHTML; }
        function addChat(s, t) {
            const cb = document.getElementById('chat-box');
            cb.innerHTML += `<div class="chat-line"><span class="text-amber-500 font-bold">${s}:</span> ${t}</div>`;
            cb.scrollTop = cb.scrollHeight;
        }
    </script>
</body>
</html>
